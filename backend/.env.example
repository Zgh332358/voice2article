# 服务配置
APP_ENV=development
APP_NAME=voice-backend
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 阶跃星辰 API（W2 起使用）
STEP_API_KEY=
STEP_API_BASE_URL=https://api.stepfun.com/v1
STEP_LLM_MODEL=step-2-16k
STEP_STT_MODEL=step-asr

# 数据库（W1 Day 3-4 起使用）
DATABASE_URL=postgresql+asyncpg://voice:voice_dev@localhost:5432/voice

# Redis（按需启用）
REDIS_URL=redis://localhost:6379/0

# JWT（W1 Day 3-4 起使用）
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
